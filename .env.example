# =============================================================================
# music-station — 部署 .env 模板
# =============================================================================
#
# 用法：
#   cp .env.example .env
#   填下面几个值
# =============================================================================

# ----------------------------------------------------------------------------
# 1) HTTP 监听
# ----------------------------------------------------------------------------
# 端口号；smart-trip MCP 用了 3001，music-station 默认 3002
PORT=3002

# 监听地址；默认 loopback（靠 Tailscale serve 暴露）
HOST=127.0.0.1

# ----------------------------------------------------------------------------
# 2) 媒体库目录（跟 smart-trip music MCP 共享同一个目录）
# ----------------------------------------------------------------------------
MUSIC_DIR=/opt/music

# ----------------------------------------------------------------------------
# 3a) SQLite 数据库文件位置
# ----------------------------------------------------------------------------
DB_PATH=/var/lib/music-station/library.db

# ----------------------------------------------------------------------------
# 3b) 封面图存储目录（搜索/上传后保存到这里，文件名是 <track_id>.<ext>）
# ----------------------------------------------------------------------------
COVER_DIR=/opt/music-covers

# ----------------------------------------------------------------------------
# 3c) 歌词存储目录（按 track_id 命名 <id>.lrc；播放页"下载歌词"按钮写入）
# ----------------------------------------------------------------------------
LYRICS_DIR=/opt/music/lyrics

# ----------------------------------------------------------------------------
# 4) 公网 base URL —— 用来构造播放链接（带在 API 响应里给前端）
# ----------------------------------------------------------------------------
# Tailscale Funnel 的完整 URL，不带尾斜杠
# 注意：MP3 的实际流是 smart-trip MCP 的 /audio/* 路由提供的
PUBLIC_URL=https://debian.tail4cfa2.ts.net

# ----------------------------------------------------------------------------
# 5) 管理员密码（S5 加 auth 时启用，S1-S4 不需要）
# ----------------------------------------------------------------------------
# 生成：openssl rand -base64 16
# ADMIN_PASSWORD=
